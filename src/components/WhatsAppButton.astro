---
/**
 * WhatsAppButton — botão flutuante de contato via WhatsApp (FND-05 · ENT-01).
 *
 * Botão fixo no canto inferior direito, presente em TODAS as páginas (montado
 * pelo BaseLayout). Abre o WhatsApp em nova aba (target=_blank, rel=noopener)
 * com mensagem pré-preenchida.
 *
 * O link wa.me vem da fonte única de contato (src/data/site.js → whatsappUrl).
 * Para trocar o número de WhatsApp, edite APENAS `whatsapp` em src/data/site.js.
 *
 * ⚠️ O número atual (555130223066 = 51 3022-3066) é o telefone FIXO da KLIT;
 *    confirme que ele tem WhatsApp ativo. Detalhes/aviso em src/data/site.js.
 *
 * Tokens usados: --color-accent/primary-contrast, --radius-full, --shadow-lg,
 *   --space-*, --transition-base.  Sem libs externas, sem hex hardcoded.
 */
import { whatsappUrl } from "../data/site.js";
---

<a
  class="whatsapp-fab"
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar no WhatsApp"
  title="Falar no WhatsApp"
>
  <svg
    class="whatsapp-fab__icon"
    viewBox="0 0 24 24"
    width="28"
    height="28"
    fill="currentColor"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.71.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"
    ></path>
  </svg>
  <span class="visually-hidden">Falar no WhatsApp</span>
</a>

<style>
  .whatsapp-fab {
    position: fixed;
    right: var(--space-5);
    bottom: var(--space-5);
    z-index: 200;

    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-full);

    /* Cor de destaque do tema; ícone usa o contraste sobre a primária */
    background-color: var(--color-accent);
    color: var(--color-primary-contrast);
    box-shadow: var(--shadow-lg);

    transition:
      transform var(--transition-base),
      background-color var(--transition-base);
  }

  .whatsapp-fab:hover,
  .whatsapp-fab:focus-visible {
    transform: scale(1.08);
    text-decoration: none;
  }

  .whatsapp-fab__icon {
    display: block;
  }

  /* Em telas muito estreitas, encolhe um pouco e aproxima da borda */
  @media (max-width: 480px) {
    .whatsapp-fab {
      right: var(--space-4);
      bottom: var(--space-4);
      width: 3.25rem;
      height: 3.25rem;
    }
  }
</style>
