---
/**
 * Container — wrapper de largura máxima centralizado.
 *
 * Centraliza o conteúdo com padding lateral responsivo. Usado dentro de
 * Section (ou direto) para limitar a largura de leitura em telas largas.
 *
 * Props:
 *   - size: "sm" | "md" | "lg" (default "lg") — largura máxima do container.
 *   - as:   tag HTML do wrapper (default "div").
 *
 * Tokens usados: --container-sm/md/lg, --container-pad.
 */
interface Props {
  size?: "sm" | "md" | "lg";
  as?: keyof HTMLElementTagNameMap;
}

const { size = "lg", as: Tag = "div" } = Astro.props;
---

<Tag class:list={["container", `container--${size}`]}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }
  .container--sm {
    max-width: var(--container-sm);
  }
  .container--md {
    max-width: var(--container-md);
  }
  .container--lg {
    max-width: var(--container-lg);
  }
</style>
