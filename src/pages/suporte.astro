---
// Página SUPORTE (esqueleto) — Fase 1, plano 01-03.
// Usa o BaseLayout (Header + Footer + WhatsApp flutuante vêm do layout).
// Canais e conteúdo real de suporte chegam na Fase 2.
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
---

<BaseLayout
  title="KLIT — Suporte"
  description="Suporte da KLIT. Canais de atendimento e conteúdo completo em breve."
>
  <Section>
    <Container size="md">
      <h1>Suporte</h1>
      <p>
        Esta é a página de Suporte em estrutura (esqueleto). Na Fase 2 ela
        reunirá os canais de atendimento e as informações de suporte aos
        clientes da KLIT.
      </p>
    </Container>
  </Section>
</BaseLayout>
