---
// Página CONTATO (esqueleto) — Fase 1, plano 01-03.
// Usa o BaseLayout (Header + Footer + WhatsApp flutuante vêm do layout).
// Formulário e dados completos chegam na Fase 2. O telefone fixo 51 3022-3066
// e o endereço já aparecem no Footer do layout.
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
---

<BaseLayout
  title="KLIT — Contato"
  description="Fale com a KLIT em Porto Alegre. Telefone 51 3022-3066. Formulário em breve."
>
  <Section>
    <Container size="md">
      <h1>Contato</h1>
      <p>
        Esta é a página de Contato em estrutura (esqueleto). Na Fase 2 ela trará
        o formulário e os atalhos de atendimento. O telefone (51 3022-3066) e o
        endereço já estão disponíveis no rodapé, e o botão flutuante de WhatsApp
        acompanha você em todas as páginas.
      </p>
    </Container>
  </Section>
</BaseLayout>
