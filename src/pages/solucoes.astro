---
// Página SOLUÇÕES (esqueleto) — Fase 1, plano 01-03.
// Usa o BaseLayout (Header + Footer + WhatsApp flutuante vêm do layout).
// As 9 soluções da KLIT chegam na Fase 2.
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
---

<BaseLayout
  title="KLIT — Soluções"
  description="Soluções de tecnologia e segurança da KLIT. Conteúdo completo em breve."
>
  <Section>
    <Container size="md">
      <h1>Soluções</h1>
      <p>
        Aqui ficarão as soluções da KLIT. Esta página está em estrutura
        (esqueleto) nesta fase; na Fase 2 ela trará o portfólio completo de
        serviços de tecnologia e segurança.
      </p>
    </Container>
  </Section>
</BaseLayout>
