---
// Página HOME — Fase 2.
// Parte 1 (02-01): Hero (sem slider) + Segurança em destaque + tese econômica.
// Parte 2 (02-02): Soluções em 3 pilares (9 marcas) + Parceiros + Institucional + CTA final.
// Seções na ordem: hero → segurança → tese → pilares → parceiros → institucional → CTA final.
//   CNT-01 (hero) · CNT-02 (segurança) · CNT-04 (tese) — parte 1.
//   CNT-03 (pilares/9) · CNT-05 (parceiros) · CNT-06 (institucional) · CNT-10 — parte 2.
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import { solucoes, pilares, solucoesPorPilar, PILAR } from "../data/solucoes.js";
import { whatsappUrl } from "../data/site.js";
import { href } from "../utils/links.js";

// Os 3 cards de Segurança vêm do MÓDULO de dados (fonte única de verdade) —
// não redigitamos os nomes inline, garantindo consistência das marcas.
const segurancaSolucoes = solucoesPorPilar(PILAR.SEGURANCA);

// Parceiros tecnológicos (CNT-05) — lista textual elegante (chips).
// TODO: logos oficiais a fornecer pelo usuário (não baixar logos de terceiros).
const parceiros = [
  "VMware",
  "Trend Micro",
  "Microsoft",
  "Cisco",
  "SolarWinds",
  "Google",
  "Azure",
  "AWS",
];

// Institucional (CNT-06) — copy reescrita SEM os typos do site antigo
// (sem "Outsoursing", "Tecnico" nem "referencia"; "referência" com acento).
const valores = [
  "Cliente satisfeito",
  "Ética",
  "Inovação",
  "Sustentabilidade",
  "Lucratividade",
];
---

<BaseLayout
  title="KLIT — Infraestrutura de TI gerenciada e segura"
  description="KLIT — infraestrutura de TI gerenciada e segura para empresas: do dado à rede à nuvem, com investimento inicial nulo e suporte especializado."
>
  {/* ============ Seção 1 — Hero (CNT-01) ============ */}
  <Section id="hero">
    <Container size="md">
      <div class="hero">
        <p class="hero__eyebrow">Infraestrutura de TI gerenciada e segura</p>
        <h1 class="hero__title">
          Infraestrutura de TI gerenciada e segura para sua empresa.
        </h1>
        <p class="hero__subtitle">
          Do dado à rede à nuvem — com investimento inicial nulo e suporte de
          quem entende do seu negócio.
        </p>
        <div class="hero__ctas">
          <Button variant="primary" href={whatsappUrl} target="_blank" rel="noopener noreferrer">Falar no WhatsApp</Button>
          <Button variant="secondary" href={href("/solucoes")}>Conheça as soluções</Button>
        </div>
      </div>
    </Container>
  </Section>

  {/* ============ Seção 2 — Segurança em destaque (CNT-02) ============ */}
  <Section id="seguranca" tone="dark">
    <Container>
      <div class="seg__head">
        <h2 class="seg__title">Segurança de ponta a ponta</h2>
        <p class="seg__subtitle">
          Protegemos cada camada da sua operação: do <strong>dado</strong> ao
          <strong>uso</strong> à <strong>rede</strong> — com monitoramento
          contínuo e gestão especializada.
        </p>
      </div>

      <ul class="seg__grid">
        {
          segurancaSolucoes.map((sol) => (
            <li class="seg__item">
              <Card title={sol.nome}>
                <p>{sol.descritor}</p>
              </Card>
            </li>
          ))
        }
      </ul>

      <p class="seg__prova">
        Tecnologia validada por parceiros líderes de mercado, como
        <strong>Trend Micro</strong> e <strong>Cisco</strong>.
      </p>
    </Container>
  </Section>

  {/* ============ Seção 3 — Tese econômica (CNT-04) ============ */}
  <Section id="investimento">
    <Container size="md">
      <div class="tese">
        <p class="tese__eyebrow">Modelo de serviço</p>
        <h2 class="tese__title">Investimento inicial nulo</h2>
        <p class="tese__lead">
          Infraestrutura como serviço: você troca o gasto de capital
          (<abbr title="Capital Expenditure">CAPEX</abbr>) por um custo
          operacional (<abbr title="Operational Expenditure">OPEX</abbr>)
          previsível, com um parceiro único responsável pelo seu ambiente de TI.
        </p>
        <p class="tese__mobi">
          E mobilidade de verdade: <strong>trabalhe de qualquer lugar, a
          qualquer momento.</strong>
        </p>
      </div>
    </Container>
  </Section>

  {/* ============ Seção 4 — Soluções em 3 pilares (CNT-03) ============ */}
  {/* As 9 marcas vêm do MÓDULO de dados (iteração dos 3 pilares); nada inline. */}
  <Section id="solucoes">
    <Container>
      <div class="sol__head">
        <p class="sol__eyebrow">Portfólio</p>
        <h2 class="sol__title">Soluções para toda a sua TI</h2>
        <p class="sol__subtitle">
          Nove soluções organizadas em três pilares — da segurança à nuvem,
          da operação à consultoria — para cobrir a infraestrutura inteira da
          sua empresa.
        </p>
      </div>

      <div class="sol__pilares">
        {
          pilares.map((pilar) => (
            <div class="pilar">
              <div class="pilar__head">
                <h3 class="pilar__titulo">{pilar.titulo}</h3>
                <p class="pilar__desc">{pilar.descricao}</p>
              </div>
              <ul class="pilar__grid">
                {solucoesPorPilar(pilar.id).map((sol) => (
                  <li class="pilar__item">
                    <Card as="article" title={sol.nome}>
                      <p>{sol.descritor}</p>
                    </Card>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="sol__cta">
        <Button variant="secondary" href={href("/solucoes")}>
          Ver todas as soluções
        </Button>
      </div>
    </Container>
  </Section>

  {/* ============ Seção 5 — Parceiros (CNT-05) ============ */}
  {/* TODO: logos oficiais a fornecer pelo usuário (não baixar logos de terceiros). */}
  <Section id="parceiros">
    <Container>
      <div class="parc__head">
        <p class="parc__eyebrow">Ecossistema</p>
        <h2 class="parc__title">Tecnologias e parceiros</h2>
        <p class="parc__subtitle">
          Trabalhamos com as principais plataformas do mercado para entregar
          uma infraestrutura confiável de ponta a ponta.
        </p>
      </div>

      <ul class="parc__chips">
        {
          parceiros.map((nome) => (
            <li class="parc__chip">{nome}</li>
          ))
        }
      </ul>
    </Container>
  </Section>

  {/* ============ Seção 6 — Institucional: Missão/Visão/Valores (CNT-06) ============ */}
  <Section id="sobre">
    <Container>
      <div class="inst__head">
        <p class="inst__eyebrow">Quem somos</p>
        <h2 class="inst__title">A KLIT</h2>
      </div>

      <div class="inst__grid">
        <Card title="Missão">
          <p>
            Conquistar e fidelizar clientes, garantindo eficácia aos usuários,
            mobilidade e redução de custos.
          </p>
        </Card>
        <Card title="Visão">
          <p>Ser referência nacional nos segmentos em que atua.</p>
        </Card>
      </div>

      <div class="inst__valores">
        <h3 class="inst__valores-titulo">Valores</h3>
        <ul class="inst__valores-lista">
          {
            valores.map((v) => (
              <li class="inst__valor">{v}</li>
            ))
          }
        </ul>
      </div>
    </Container>
  </Section>

  {/* ============ Seção 7 — CTA final + contato rápido ============ */}
  <Section tone="dark">
    <Container size="md">
      <div class="cta">
        <h2 class="cta__title">Vamos cuidar da TI da sua empresa?</h2>
        <p class="cta__lead">
          Fale com a KLIT e descubra como ter uma infraestrutura gerenciada,
          segura e com custo previsível — sem investimento inicial.
        </p>
        <div class="cta__actions">
          <Button variant="primary" href={whatsappUrl} target="_blank" rel="noopener noreferrer">Falar no WhatsApp</Button>
          <Button variant="secondary" href={href("/contato")}>Ir para Contato</Button>
        </div>
        <p class="cta__fone">
          Ou ligue para
          <a class="cta__fone-link" href="tel:+555130223066">51 3022-3066</a>.
        </p>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
    padding-block: var(--space-6);
    max-width: var(--container-sm);
  }

  .hero__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hero__title {
    margin: 0;
    font-size: var(--font-size-4xl);
    line-height: var(--line-tight);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .hero__subtitle {
    margin: 0;
    font-size: var(--font-size-xl);
    line-height: var(--line-snug);
    color: var(--color-text-muted);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-3);
  }

  /* ===== Segurança em destaque (sobre fundo escuro via Section tone="dark") ===== */
  .seg__head {
    max-width: var(--container-sm);
    margin-bottom: var(--space-7);
  }

  .seg__title {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-3xl);
    line-height: var(--line-tight);
    font-weight: var(--font-weight-bold);
    color: var(--color-dark-text);
  }

  .seg__subtitle {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--line-base);
    color: var(--color-dark-text-muted);
  }

  .seg__subtitle strong {
    color: var(--color-accent);
    font-weight: var(--font-weight-semibold);
  }

  .seg__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .seg__item {
    display: flex;
  }

  /* O Card já é uma superfície clara; aqui só garantimos que ocupe a célula. */
  .seg__item :global(.card) {
    width: 100%;
  }

  .seg__prova {
    margin: var(--space-7) 0 0;
    font-size: var(--font-size-base);
    color: var(--color-dark-text-muted);
  }

  .seg__prova strong {
    color: var(--color-dark-text);
    font-weight: var(--font-weight-semibold);
  }

  /* ===== Tese econômica ===== */
  .tese {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    border-left: 4px solid var(--color-primary);
    padding-left: var(--space-6);
  }

  .tese__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .tese__title {
    margin: 0;
    font-size: var(--font-size-3xl);
    line-height: var(--line-tight);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .tese__lead {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--line-base);
    color: var(--color-text-muted);
    max-width: var(--container-sm);
  }

  .tese__lead abbr {
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .tese__mobi {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--line-snug);
    color: var(--color-text);
  }

  .tese__mobi strong {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
  }

  /* ===== Soluções em 3 pilares ===== */
  .sol__head {
    max-width: var(--container-sm);
    margin-bottom: var(--space-8);
  }

  .sol__eyebrow {
    margin: 0 0 var(--space-3);
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .sol__title {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-3xl);
    line-height: var(--line-tight);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .sol__subtitle {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--line-base);
    color: var(--color-text-muted);
  }

  .sol__pilares {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .pilar__head {
    max-width: var(--container-sm);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .pilar__titulo {
    margin: 0 0 var(--space-2);
    font-size: var(--font-size-2xl);
    line-height: var(--line-snug);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
  }

  .pilar__desc {
    margin: 0;
    font-size: var(--font-size-base);
    line-height: var(--line-base);
    color: var(--color-text-muted);
  }

  .pilar__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-5);
  }

  .pilar__item {
    display: flex;
  }

  .pilar__item :global(.card) {
    width: 100%;
  }

  .sol__cta {
    margin-top: var(--space-8);
    display: flex;
  }

  /* ===== Parceiros (chips textuais — sem logos de terceiros) ===== */
  .parc__head {
    max-width: var(--container-sm);
    margin-bottom: var(--space-7);
  }

  .parc__eyebrow {
    margin: 0 0 var(--space-3);
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .parc__title {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-3xl);
    line-height: var(--line-tight);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .parc__subtitle {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--line-base);
    color: var(--color-text-muted);
  }

  .parc__chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .parc__chip {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background-color: var(--color-surface-alt);
    color: var(--color-text);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    box-shadow: var(--shadow-sm);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .parc__chip:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  /* ===== Institucional (Missão / Visão / Valores) ===== */
  .inst__head {
    max-width: var(--container-sm);
    margin-bottom: var(--space-7);
  }

  .inst__eyebrow {
    margin: 0 0 var(--space-3);
    color: var(--color-primary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .inst__title {
    margin: 0;
    font-size: var(--font-size-3xl);
    line-height: var(--line-tight);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .inst__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
    margin-bottom: var(--space-7);
  }

  .inst__grid :global(.card) {
    height: 100%;
  }

  .inst__valores {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }

  .inst__valores-titulo {
    margin: 0 0 var(--space-5);
    font-size: var(--font-size-2xl);
    line-height: var(--line-snug);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .inst__valores-lista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
  }

  .inst__valor {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .inst__valor::before {
    content: "";
    width: var(--space-2);
    height: var(--space-2);
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
  }

  /* ===== CTA final (sobre fundo escuro via Section tone="dark") ===== */
  .cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
    max-width: var(--container-sm);
  }

  .cta__title {
    margin: 0;
    font-size: var(--font-size-3xl);
    line-height: var(--line-tight);
    font-weight: var(--font-weight-bold);
    color: var(--color-dark-text);
  }

  .cta__lead {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--line-base);
    color: var(--color-dark-text-muted);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  /* Botão secundário sobre fundo escuro: garante contraste com tokens dark. */
  .cta__actions :global(.btn--secondary) {
    color: var(--color-dark-text);
    border-color: var(--color-dark-text);
  }
  .cta__actions :global(.btn--secondary:hover) {
    background-color: var(--color-dark-text);
    color: var(--color-dark-bg);
  }

  .cta__fone {
    margin: var(--space-3) 0 0;
    font-size: var(--font-size-base);
    color: var(--color-dark-text-muted);
  }

  .cta__fone-link {
    color: var(--color-dark-text);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .cta__fone-link:hover {
    color: var(--color-accent);
  }

  /* ===== Responsivo ===== */
  @media (max-width: 900px) {
    .seg__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero__title {
      font-size: var(--font-size-3xl);
    }
    .hero__subtitle {
      font-size: var(--font-size-lg);
    }
    .hero__ctas {
      width: 100%;
    }
    .seg__grid {
      grid-template-columns: 1fr;
    }
    .tese {
      padding-left: var(--space-5);
    }
    .pilar__grid {
      grid-template-columns: 1fr;
    }
    .inst__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
