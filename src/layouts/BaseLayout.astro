---
/**
 * BaseLayout — layout raiz do site KLIT (FND-05, FND-06, FND-08).
 *
 * Responsabilidades:
 *   - <html lang="pt-BR" data-theme="ocean"> com estado SSR inicial.
 *   - <head> com SEO real (title/description via props + Open Graph, twitter:card
 *     e <link rel="canonical"> derivados de Astro.url/Astro.site), favicon do
 *     brand, viewport e a fonte/tokens (via global.css).
 *   - ANTI-FLASH CANÔNICO: o <script is:inline> abaixo é o ÚNICO ponto do site
 *     que reaplica o tema salvo (localStorage "klit-theme") ANTES do paint, em
 *     TODAS as páginas. Por isso o snippet inline foi REMOVIDO do ThemeSwitcher
 *     (que mantém só a lógica client-side de clique/persistência/estado ativo).
 *   - <body> renderiza Header (slot do topo), <slot/> (conteúdo da página),
 *     Footer e o WhatsAppButton flutuante — presentes em todas as páginas.
 *
 * Props:
 *   - title:       <title> da página + og:title/twitter:title (default pt-BR).
 *   - description: <meta name="description"> + og/twitter description (default).
 *   - ogImage:     caminho da imagem de social share (default logo do brand);
 *                  resolvido para URL absoluta via Astro.site.
 *   - ogType:      tipo Open Graph (default "website").
 *
 * canonical/og:url são derivados de `new URL(Astro.url.pathname, Astro.site)`
 * (Astro.site = https://klit.com.br, definido em astro.config).
 *
 * Tokens/estilos chegam via global.css (que importa tokens.css + fonte Inter).
 */
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title = "KLIT — Tecnologia & Segurança",
  description =
    "KLIT — soluções de tecnologia e segurança em Porto Alegre. Conteúdo completo em breve.",
  ogImage = "/brand/ocean/horizontal-2048.png",
  ogType = "website",
} = Astro.props;

// canonical + og:url + og:image absolutos a partir do site de produção.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageAbs = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="pt-BR" data-theme="ocean">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Canonical (SEO) — aponta para o host de produção por página */}
    <link rel="canonical" href={canonical} />

    {/* Open Graph (compartilhamento social) */}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:site_name" content="KLIT" />
    <meta property="og:locale" content="pt_BR" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="icon" type="image/png" href="/brand/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- ============================================================
         ANTI-FLASH CANÔNICO (FND-08) — ponto ÚNICO do site.
         is:inline => executa imediatamente, sem type=module / sem defer,
         ANTES de qualquer CSS/render. Reaplica o tema salvo para que NÃO
         haja flash de cor em nenhuma página. O ThemeSwitcher NÃO duplica
         mais este snippet (só trata cliques/persistência).
         ============================================================ -->
    <script is:inline>
      (function () {
        try {
          var THEME_KEY = "klit-theme";
          var VALID = ["ocean", "navy", "sky", "soft"];
          var saved = localStorage.getItem(THEME_KEY);
          var theme = VALID.indexOf(saved) !== -1 ? saved : "ocean";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "ocean");
        }
      })();
    </script>
  </head>
  <body>
    {/* Skip-to-content (ENT-05): primeiro foco tabulável; pula direto ao <main>. */}
    <a href="#conteudo" class="skip-link">Pular para o conteúdo</a>
    <Header />
    <main id="conteudo">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>

<style>
  /* Skip-link (ENT-05): escondido fora da tela por padrão; visível ao receber
     foco por teclado. Só tokens — zero hex; respeita os 4 temas. */
  .skip-link {
    position: fixed;
    top: var(--space-3);
    left: var(--space-3);
    z-index: 1000;
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-primary);
    color: var(--color-primary-contrast);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    /* Fora da tela até receber foco. */
    transform: translateY(-150%);
    transition: transform var(--transition-base);
  }
  .skip-link:focus,
  .skip-link:focus-visible {
    transform: translateY(0);
    outline: 2px solid var(--color-primary-contrast);
    outline-offset: 2px;
    text-decoration: none;
  }
</style>
